{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install --prefix savvy-web",
  "buildCommand": "npm run build --prefix savvy-web",
  "outputDirectory": "savvy-web/dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
