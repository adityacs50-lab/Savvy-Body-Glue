{
  "version": 2,
  "builds": [
    {
      "src": "api/cart.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "webgl.js",
      "use": "@vercel/static"
    },
    {
      "src": "product-photo.js",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/cart",
      "dest": "api/cart.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "assets/$1"
    },
    {
      "src": "/styles.css",
      "dest": "styles.css"
    },
    {
      "src": "/responsive.css",
      "dest": "responsive.css"
    },
    {
      "src": "/webgl.css",
      "dest": "webgl.css"
    },
    {
      "src": "/product-photo.css",
      "dest": "product-photo.css"
    },
    {
      "src": "/app.js",
      "dest": "app.js"
    },
    {
      "src": "/webgl.js",
      "dest": "webgl.js"
    },
    {
      "src": "/product-photo.js",
      "dest": "product-photo.js"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
